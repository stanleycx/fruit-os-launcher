<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/clock_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_rounded_bg"
    android:padding="14dp">

    <!-- Date (jour + date) — auto-rafraîchie -->
    <TextClock
        android:id="@+id/clock_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:format12Hour="EEEE d MMMM"
        android:format24Hour="EEEE d MMMM"
        android:textColor="#FF9F0A"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:singleLine="true" />

    <!-- Heure — auto-rafraîchie -->
    <TextClock
        android:id="@+id/clock_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-2dp"
        android:format12Hour="h:mm"
        android:format24Hour="HH:mm"
        android:textColor="#FFFFFF"
        android:textSize="52sp"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        android:singleLine="true" />

</LinearLayout>
