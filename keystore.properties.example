# Modèle de configuration de signature release.
# 1. Copie ce fichier en "keystore.properties" (SANS .example)
# 2. Remplis les 4 valeurs avec celles de TA clé (voir PUBLISHING.md)
# 3. keystore.properties et le .jks sont gitignorés : ne les committe JAMAIS.

storeFile=../launcher-release.jks
storePassword=TON_MOT_DE_PASSE_KEYSTORE
keyAlias=launcher
keyPassword=TON_MOT_DE_PASSE_CLE
